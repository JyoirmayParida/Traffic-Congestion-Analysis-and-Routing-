# Model backend selector: 'xgboost_json' | 'onnx'
MODEL_BACKEND=xgboost_json

# Frontend origin for CORS — never use wildcard in production
CORS_ALLOWED_ORIGIN=http://localhost:3000

# Background scheduler tick rate in seconds
SCHEDULER_INTERVAL_SEC=30

# Path to Firebase service account key (never commit the real file)
GOOGLE_APPLICATION_CREDENTIALS=./backend/serviceAccountKey.json
